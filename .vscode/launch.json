{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Streamlit App",
            "type": "debugpy",          
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "app.py",
                "--server.port=8501",
                "--server.address=localhost"
            ]
        },
        {
            "name": "Debug Current File",
            "type": "debugpy",          
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
}